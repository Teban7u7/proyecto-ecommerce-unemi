# =============================================================================
# Licorería Virtual Backend — Variables de Entorno (copia este archivo a .env)
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-this-to-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (SQLite para desarrollo local, PostgreSQL para Docker/producción)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/licoreria_db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# =============================================================================
# NUVEI / PAYMENTEZ — CREDENCIALES STAGING (pedir al equipo)
# =============================================================================
NUVEI_APP_CODE_CLIENT_STG=TEBANSTG-EC-CLIENT
NUVEI_APP_KEY_CLIENT_STG=your-client-app-key-stg
NUVEI_APP_CODE_SERVER_STG=TEBANSTG-EC-SERVER
NUVEI_APP_KEY_SERVER_STG=your-server-app-key-stg

# =============================================================================
# NUVEI / PAYMENTEZ — CREDENCIALES PRODUCCIÓN
# =============================================================================
NUVEI_APP_CODE_CLIENT_PROD=your-client-app-code-prod
NUVEI_APP_KEY_CLIENT_PROD=your-client-app-key-prod
NUVEI_APP_CODE_SERVER_PROD=your-server-app-code-prod
NUVEI_APP_KEY_SERVER_PROD=your-server-app-key-prod

# WhatsApp
WHATSAPP_BUSINESS_NUMBER=593XXXXXXXXX

# Node Payment Service
PAYMENT_SERVICE_URL=http://localhost:3001
PAYMENT_SERVICE_SECRET=internal-shared-secret
